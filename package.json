{
  "name": "dev-assistant-mcp-server",
  "version": "1.0.0",
  "description": "Token-efficient MCP server for file access, Jarvis bot management, and lab data processing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build:bundle": "tsc && esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=build/bundle.cjs",
    "build:exe": "npm run build:bundle && pkg build/bundle.cjs --targets node18-win-x64 --output build/dev-assistant-mcp.exe",
    "watch:exe": "nodemon --watch src --ext ts --exec \"npm run build:exe\" --delay 2"
  },
  "pkg": {
    "assets": [],
    "targets": ["node18-win-x64"]
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.14",
    "typescript": "^5.0.0"
  }
}
